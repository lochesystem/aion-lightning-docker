# =============================================================================
# Copiar para compose.env (NÃO commitar compose.env — está no .gitignore)
# Uso: docker compose --env-file compose.env up -d --build
# =============================================================================

# Raiz do aion-lightning-work (pasta que contém aion-lightning-2.7/).
# Windows: C:/Users/teuuser/aion-lightning-work
# Linux VPS: /home/ubuntu/aion-lightning-work ou /opt/aion-lightning-work
AION_WORK_ROOT=/caminho/absoluto/para/aion-lightning-work

# MariaDB dentro do contentor — usa password forte em produção
MYSQL_ROOT_PASSWORD=change-me-root

# Referência para overlays database.properties (initdb cria este user)
AION_DB_USER=aion
AION_DB_PASSWORD=aionlocal

# JVM Game Server (opcional; o entrypoint do game pode ignorar se não estiver ligado no compose)
JAVA_OPTS=-Xms512m -Xmx1024m -server

# IPv4 que os CLIENTES usam para alcançar ESTE host (público da VPS, LAN, ou Tailscale).
# Modo bridge: usado para chatserver.network.client.advertise no entrypoint do chat.
# Alinha também config-overrides/game/network/ipconfig.xml (default / faixas 100.64/10).
# Exemplos: 203.0.113.50 | 192.168.1.100 | 100.x.x.x (tailscale ip -4)
AION_PUBLIC_ADDRESS=203.0.113.50

